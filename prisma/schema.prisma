generator client {
  provider      = "prisma-client"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id               String            @id @default(cuid())
  name             String
  country          String
  sector           Sector
  capacityMW       Float?
  capacityUnit     String?
  capacityValue    Float?
  ownershipType    OwnershipType
  subCategory      SubCategory
  status           AssetStatus
  commissionedYear Int?
  originalCostUsd  Float?

  description      String  @db.Text
  strategicContext String? @db.Text

  scores      DimensionScore[]
  documents   Document[]
  briefs      ICBrief[]
  pathActions PathToGoAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DimensionScore {
  id         String    @id @default(cuid())
  asset      Asset     @relation(fields: [assetId], references: [id])
  assetId    String
  dimension  Dimension
  score      Int
  rationale  String    @db.Text
  confidence Float
  scoredBy   String
  scoredAt   DateTime  @default(now())

  @@unique([assetId, dimension])
}

model PathToGoAction {
  id               String    @id @default(cuid())
  asset            Asset     @relation(fields: [assetId], references: [id])
  assetId          String
  description      String    @db.Text
  affectsDimension Dimension
  scoreUplift      Int
  estimatedCost    String?
  estimatedTime    String?
}

model Document {
  id            String   @id @default(cuid())
  asset         Asset    @relation(fields: [assetId], references: [id])
  assetId       String
  filename      String
  documentType  DocType
  contentHash   String
  extractedText String?  @db.Text
  uploadedAt    DateTime @default(now())
}

model ICBrief {
  id          String   @id @default(cuid())
  asset       Asset    @relation(fields: [assetId], references: [id])
  assetId     String
  version     Int      @default(1)
  content     String   @db.Text
  generatedAt DateTime @default(now())
  generatedBy String
}

enum Sector {
  POWER_HYDRO
  POWER_SOLAR
  POWER_THERMAL
  POWER_TRANSMISSION
  TRANSPORT_ROAD
  TRANSPORT_RAIL
  TRANSPORT_BRIDGE
  TRANSPORT_PORT
  MIDSTREAM_GAS
  ICT_DATACENTER
}

enum OwnershipType {
  STATE_FULL
  STATE_MAJORITY
  IPP_PRIVATE
  IPP_MIXED
  CONCESSIONED
}

enum SubCategory {
  STRANDED_BROWNFIELD
  UNDERPERFORMING_BROWNFIELD
  OPERATIONAL_IPP_REFINANCING
  OPERATIONAL_PUBLIC_FOR_CONCESSION
  GREENFIELD_IPT
}

enum AssetStatus {
  OPERATIONAL
  OPERATIONAL_BELOW_CAPACITY
  MOTHBALLED
  UNDER_REFURB
}

enum Dimension {
  REVENUE_MATURITY
  DEBT_COMPLEXITY
  CONCESSION_READINESS
  DATA_AVAILABILITY
  REGULATORY_ENVIRONMENT
  MODERNISATION_RISK
}

enum DocType {
  TECHNICAL_REPORT
  FINANCIAL_REPORT
  REGULATORY_FILING
  PPA
  CONCESSION_AGREEMENT
  IC_TEMPLATE
  OTHER
}
